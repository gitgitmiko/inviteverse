# Salin ke .env dan isi dari Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Nomor WhatsApp admin (digit internasional tanpa +), contoh: 62812xxxxxxxx
# Kosong = tombol WA tidak membuka chat; antrian “Dibuatin Admin” tetap jalan
VITE_ADMIN_WHATSAPP=

# Opsional: izinkan tombol "Simulasi (dev)" di /harga tanpa Midtrans
# VITE_ALLOW_PLAN_SIMULATE=true
